# Auto-renew backend env — copy to .env (Docker) or .env.production (systemd)

# Required
AUTORENEW_HOT_WALLET_KEY=0xPASTE_PRIVATE_KEY_FROM_GENERATOR

# Where the SQLite db lives (must be writable by the service user)
AUTORENEW_DB_PATH=/srv/gotchicloset/data/autorenew.db

# Base RPC — public is fine to start; switch to a paid one (Alchemy/QuickNode) if rate-limited
BASE_RPC_URL=https://mainnet.base.org

# Aavegotchi subgraph on Base — leave default unless you know what you're doing
SUBGRAPH_URL=https://api.goldsky.com/api/public/project_cmh3flagm0001r4p25foufjtt/subgraphs/aavegotchi-core-base/prod/gn

# Server port (the cron + REST run inside the same Node process)
PORT=8787

# CORS — comma-separated list of allowed origins for the REST API
VITE_DEV_ALLOWED_ORIGINS=https://www.gotchicloset.com,https://gotchicloset.com,http://localhost:5000
