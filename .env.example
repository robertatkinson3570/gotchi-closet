# Client-visible (Vite) environment variables
# These are exposed to the browser at build time.

# REQUIRED (client + /api): Goldsky subgraph endpoint
# Get from: https://goldsky.com (Aavegotchi Core Base subgraph)
VITE_GOTCHI_SUBGRAPH_URL=

# REQUIRED (client + /api): Base RPC URL
# Get from: https://chainlist.org or your RPC provider
VITE_BASE_RPC_URL=

# REQUIRED (serverless /api): Aavegotchi diamond contract on Base
# Default: 0xA99c4B08201F2913Db8D28e71d020c4298F29dBF
VITE_GOTCHI_DIAMOND_ADDRESS=

# Optional: Site metadata
VITE_SITE_URL=https://www.gotchicloset.com

# Optional: WalletConnect project ID (required if you use wallet connect)
# Get from: https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: Donation address for the homepage
VITE_DONATION_ADDRESS=

# Optional: Partner attribution
VITE_GRIMLABS_NAME=GrimLabs
VITE_GRIMLABS_URL=https://grimlabs.xyz

# Dev-only: override Vite /api proxy target (optional)
# Example for vercel dev: http://localhost:3000
VITE_API_PROXY_URL=

# Dev-only: override allowed CORS origins for local API server
# Comma-separated list. If empty, defaults to 5173/5174/3000.
VITE_DEV_ALLOWED_ORIGINS=

# Companion AI server (set these in the VPS .env — the Express container reads them)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Leave OPENAI_API_KEY empty until the premium tier is gated behind a wallet
# signature (the /chat wallet is currently self-reported — see server/routes/companion.ts).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Wallet that receives GHST premium payments (used by /api/companion/premium/claim)
COMPANION_RECEIVING_WALLET=
BASE_RPC_URL=https://mainnet.base.org
# Persist companion memory on the mounted Docker volume (else it resets on redeploy).
# In prod set to the volume path, e.g. /srv/gotchicloset/data/companion.db
COMPANION_DB_PATH=

# Client (Vercel) — companion API base origin. The companion routes run on the VPS,
# not Vercel, so the deployed frontend must call the VPS origin directly.
# e.g. https://api.gotchicloset.com  (leave empty in local dev — the Vite proxy handles it)
VITE_COMPANION_API_URL=
# Client-side visibility of receiving wallet (for payment UI)
VITE_COMPANION_RECEIVING_WALLET=